# Example environment variables
# Copy to .env and fill in your values

# Helius API Key (for private RPC)
HELIUS_API_KEY=

# Optional: Override Solana RPC URL (if not using Helius)
# SOLANA_RPC_URL=

# Other existing variables (if any)
# Example: API_KEY_FOR_SOME_SERVICE=

# =============================================================================
# LLM Provider Keys
# =============================================================================

# NVIDIA NIM (primary)
NVIDIA_API_KEY=

# Mistral AI (backup)
MISTRAL_API_KEY=
 
# Google AI Studio
GOOGLE_API_KEY=

# Uwaga: NIM używa OPENAI_API_KEY z prefiksem nvapi-
# OPENAI_API_KEY=nvapi-twoj-klucz
 
# =============================================================================
# Telegram
# =============================================================================
 
# Token bota agenta (od @BotFather)
TELEGRAM_BOT_TOKEN=
 
# Twoje Telegram user ID (wyślij /start do bota i sprawdź logi)
TELEGRAM_ALLOWED_USERS=
