# Hermes Agent Niggvis Crypto — API Keys
# Skopiuj do ~/.hermes/.env i uzupełnij klucze.
#
# WAŻNE: NIGDY nie commituj tego pliku z prawdziwymi kluczami!
 
# =============================================================================
# LLM Provider Keys
# =============================================================================
 
# Mistral AI (primary)
MISTRAL_API_KEY=
 
# NVIDIA NIM (backup)
# Uwaga: NIM używa OPENAI_API_KEY z prefiksem nvapi-
# OPENAI_API_KEY=nvapi-twoj-klucz
 
# =============================================================================
# Telegram
# =============================================================================
 
# Token bota agenta (od @BotFather)
TELEGRAM_BOT_TOKEN=
 
# Twoje Telegram user ID (wyślij /start do bota i sprawdź logi)
# TELEGRAM_ALLOWED_USERS=
 
# Chat ID Trojan on Solana bota (do wysyłania komend tradingowych)
# Jak uzyskać: otwórz Trojan bota → wyślij wiadomość → sprawdź chat ID
# TROJAN_BOT_CHAT_ID=
 
# =============================================================================
# Solana (opcjonalnie)
# =============================================================================
 
# Prywatny RPC endpoint (Helius, QuickNode, Triton)
# Publiczny RPC ma rate limity — na produkcję warto prywatny
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
 
# =============================================================================
# Birdeye API (opcjonalnie — rozszerzone dane tokenów)
# =============================================================================
# BIRDEYE_API_KEY=
